# ═══════════════════════════════════════════════════════════════════
# SecretomeProfiler — Production Environment Template
# ═══════════════════════════════════════════════════════════════════
# Set these as Railway environment variables — do NOT commit real values
# Generate SECRET_KEY with: openssl rand -hex 32
# ═══════════════════════════════════════════════════════════════════

# ─── Database (auto-provided by Railway PostgreSQL plugin) ─────────
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db
POSTGRES_USER=secretome
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=secretome_db
POSTGRES_HOST=postgres.railway.internal
POSTGRES_PORT=5432

# ─── Redis (auto-provided by Railway Redis plugin) ─────────────────
REDIS_URL=redis://default:password@host:6379/0
CELERY_BROKER_URL=redis://default:password@host:6379/0
CELERY_RESULT_BACKEND=redis://default:password@host:6379/1

# ─── Security ──────────────────────────────────────────────────────
SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32

# ─── File Storage (Backblaze B2 — S3-compatible) ───────────────────
MINIO_ENDPOINT=s3.us-west-004.backblazeb2.com
MINIO_ROOT_USER=YOUR_BACKBLAZE_KEY_ID
MINIO_ROOT_PASSWORD=YOUR_BACKBLAZE_APPLICATION_KEY
MINIO_BUCKET=secretome-results
MINIO_SECURE=true

# ─── Application ───────────────────────────────────────────────────
DEBUG=false
HTTP_TIMEOUT=30
HTTP_MAX_RETRIES=3
OPENTARGETS_API_URL=https://api.platform.opentargets.org/api/v4/graphql
DISGENET_API_URL=https://www.disgenet.org/api

# ─── LLM (per-user keys; server key optional fallback) ─────────────
LLM_ENABLED=true
LLM_MODEL=claude-sonnet-4-5
ANTHROPIC_API_KEY=

# ─── CORS (set to your Railway frontend URL) ───────────────────────
ALLOWED_ORIGINS=https://your-frontend.up.railway.app,https://app.leverage.bio

# ─── Invite code (leave empty to allow open registration) ──────────
INVITE_CODE=

# ─── Frontend build vars (set in Railway frontend service) ─────────
VITE_API_URL=https://your-backend.up.railway.app
VITE_WS_URL=wss://your-backend.up.railway.app
